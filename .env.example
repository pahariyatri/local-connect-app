# ---------------------------------------------------------------------------
# Frontend environment. Copy to `.env.local` for local dev, or provide these
# as build args / platform env vars when deploying.
#
# NOTE: the API client appends `/api/v1` automatically, so give the bare host.
#   e.g. NEXT_PUBLIC_API_BASE_URL=https://api.pahariyatri.com
# ---------------------------------------------------------------------------

# Base URL of the backend API (no trailing /api/v1)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Razorpay public key (client-side checkout)
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Web push (optional)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Analytics / monitoring (optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_SENTRY_DSN=

# Feature flags
NEXT_PUBLIC_ENABLE_CHAT=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
