# =============================================================================
# PahariYatri — Local Connect Network App
# .gitignore — Next.js / TypeScript / Node project
# Reference: https://help.github.com/articles/ignoring-files/
# =============================================================================


# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions


# -----------------------------------------------------------------------------
# Next.js build outputs
# -----------------------------------------------------------------------------
/.next/
/out/
/build/
.next/


# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts


# -----------------------------------------------------------------------------
# Environment & secrets  ⚠️  NEVER commit real credentials
# -----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
# Keep the example file — it documents required variables
!.env.example


# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
/coverage/
/.nyc_output/
/test-results/
/playwright-report/
/playwright/.cache/


# -----------------------------------------------------------------------------
# Debug / logs
# -----------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
logs/
lerna-debug.log*


# -----------------------------------------------------------------------------
# OS & editor artefacts
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# JetBrains IDEs (WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# VS Code (keep shared settings if desired — remove the ! lines to also ignore)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# Vim / Emacs swap files
*.swp
*.swo
*~


# -----------------------------------------------------------------------------
# Vercel
# -----------------------------------------------------------------------------
.vercel/


# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Ignore local override compose files but keep the base docker-compose.yml
docker-compose.override.yml
docker-compose.local.yml


# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
# SSL / TLS private keys
*.pem
*.key
*.crt
*.p12

# Storybook static build
storybook-static/

# Turbo / monorepo cache
.turbo/

# Bundle analyser output
.analyze/
bundle-analyzer-report.html
